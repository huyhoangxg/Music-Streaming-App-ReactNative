APP_NAME="music-streaming-ai-service"
APP_VERSION="0.5.0"
APP_ENV="development"
PORT="8000"
RECOMMENDATION_MODE="hybrid-ranking"
GENRE_ANALYSIS_MODE="essentia-first"
DEFAULT_RECOMMENDATION_LIMIT="12"
DEFAULT_CANDIDATE_POOL="80"
CONTENT_WEIGHT="0.40"
COLLABORATIVE_WEIGHT="0.35"
POPULARITY_WEIGHT="0.15"
FRESHNESS_WEIGHT="0.10"
AUDIO_FETCH_TIMEOUT_SECONDS="12"
AUDIO_FETCH_MAX_BYTES="25000000"
AUDIO_SAMPLE_RATE="16000"
AUDIO_RESAMPLE_QUALITY="4"
GENRE_TOP_K="3"
GENRE_SCORE_THRESHOLD="0.15"
GENRE_CONFIDENCE_THRESHOLD="0.50"
GENRE_ANALYSIS_MOCK_ENABLED="false"
ESSENTIA_ENABLED="false"
MODELS_DIR="./models"
EMBEDDING_MODEL_PATH="./models/discogs-effnet-bs64-1.pb"
EMBEDDING_METADATA_PATH="./models/discogs-effnet-bs64-1.json"
ESSENTIA_EMBEDDING_OUTPUT_LAYER="PartitionedCall:1"
GENRE_CLASSIFIER_BACKEND="keras"
GENRE_MODEL_PATH="./models/soundwave_genre_classifier.keras"
GENRE_METADATA_PATH="./models/soundwave_genre_classifier.json"
