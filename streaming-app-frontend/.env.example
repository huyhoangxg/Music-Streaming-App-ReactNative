# Google OAuth client IDs for the Expo AuthSession login flow.
# Current Expo AuthSession versions no longer support the old auth.expo.io proxy flow reliably.
# Test Google login with a development build, not Expo Go.
# Android package / iOS bundle identifier in app.json: com.soundwave.app
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
