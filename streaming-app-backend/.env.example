PORT="5000"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/music_streaming_app"
JWT_SECRET="replace_me"
CLOUDINARY_CLOUD_NAME="replace_me"
CLOUDINARY_API_KEY="replace_me"
CLOUDINARY_API_SECRET="replace_me"
AI_SERVICE_URL="http://127.0.0.1:8000"
AI_REQUEST_TIMEOUT_MS="300000"
RECOMMENDATION_DEFAULT_LIMIT="12"

# Required for email verification. Use Resend for local/demo email delivery.
EMAIL_FROM="SoundWave <onboarding@resend.dev>"
RESEND_API_KEY="re_replace_me"

# Optional fallback for Expo Go demos on iPhone.
# Create an OAuth client with application type "TVs and Limited Input devices".
GOOGLE_DEVICE_CLIENT_ID="replace_me"
GOOGLE_DEVICE_CLIENT_SECRET="replace_me"

# Optional Gmail SMTP fallback. Leave empty when using Resend.
SMTP_HOST=""
SMTP_PORT=""
SMTP_SECURE=""
SMTP_USER=""
SMTP_PASS=""

ACRCLOUD_HOST="identify-ap-southeast-1.acrcloud.com"
ACRCLOUD_ACCESS_KEY="replace_me"
ACRCLOUD_ACCESS_SECRET="replace_me"
